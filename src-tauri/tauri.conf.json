{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rshell",
  "version": "0.1.14",
  "identifier": "dev.rshell.desktop",
  "build": {
    "frontendDist": "ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix src-tauri/ui run dev",
    "beforeBuildCommand": "npm --prefix src-tauri/ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "rshell",
        "width": 1280,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": "v1Compatible",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "targets": "all"
  },
  "plugins": {
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/touchfish1/rshell/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ4MzlFMjdFRkQ2RUM2NzIKUldSeXhtNzlmdUk1U05KVjlLNEdhc2tiVXVLeHFybkk5aUI3Smc4UWM5VnhRclVYN05VOGFjV2sK"
    }
  }
}

