{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rshell",
  "version": "0.1.0",
  "identifier": "dev.rshell.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ../ui run dev",
    "beforeBuildCommand": "npm --prefix ../ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "rshell",
        "width": 1280,
        "height": 800
      }
    ]
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"],
    "targets": "all"
  }
}
